# ─────────── База данных (SQLite) ───────────
# Путь к файлу БД. По умолчанию — локальный файл в папке prisma.
DATABASE_URL="file:./prisma/dev.db"

# ─────────── Авторизация в админке ───────────
# Секрет для подписи JWT-сессий. Сгенерируйте случайную строку, например:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="замените-на-длинный-случайный-секрет"

# Учётная запись администратора (создаётся при seed-е).
# Пароль хранится в БД в виде bcrypt-хэша.
ADMIN_LOGIN="admin"
ADMIN_PASSWORD="changeme123"

# ─────────── DeepSeek API (AI-консультант) ───────────
# Ключ берётся на https://platform.deepseek.com/api_keys
# Можно задать здесь ИЛИ в админке (раздел «ИИ-консультант»); админка приоритетнее.
DEEPSEEK_API_KEY="sk-..."
# Модель консультанта: deepseek-chat (V3) или deepseek-reasoner (R1)
DEEPSEEK_MODEL="deepseek-chat"
# Endpoint API (по умолчанию https://api.deepseek.com) — менять обычно не нужно
# DEEPSEEK_BASE_URL="https://api.deepseek.com"

# ─────────── Публичный адрес сайта (для SEO/sitemap/OG) ───────────
NEXT_PUBLIC_SITE_URL="https://krylia-kavkaza.ru"
